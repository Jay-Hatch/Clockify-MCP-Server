# Required: your Clockify API key from Clockify profile settings.
CLOCKIFY_API_KEY=

# Optional defaults, so tool calls can omit these IDs.
CLOCKIFY_WORKSPACE_ID=
CLOCKIFY_USER_ID=

# Strongly recommended for a public Railway URL.
# MCP clients should send: Authorization: Bearer <this value>
MCP_SERVER_TOKEN=

# Railway provides PORT automatically. Use 3000 locally.
PORT=3000

# Optional: override these for regional or subdomain Clockify workspaces.
# Examples:
# CLOCKIFY_API_BASE_URL=https://euc1.clockify.me/api/v1
# CLOCKIFY_REPORTS_BASE_URL=https://use2.clockify.me/report/v1
# CLOCKIFY_AUDIT_LOG_BASE_URL=https://auditlog-api.api.clockify.me/v1
CLOCKIFY_API_BASE_URL=https://api.clockify.me/api/v1
CLOCKIFY_REPORTS_BASE_URL=https://reports.api.clockify.me/v1
CLOCKIFY_AUDIT_LOG_BASE_URL=https://auditlog-api.api.clockify.me/v1

# Optional CORS origin for browser-based MCP clients.
CORS_ORIGIN=*
